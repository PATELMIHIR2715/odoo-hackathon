NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
JWT_SECRET=use-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=use-a-different-random-secret-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
# Used only by `npm.cmd run db:seed`; do not commit real values.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-to-a-secure-password
SEED_ADMIN_NAME=TransitOps Administrator
