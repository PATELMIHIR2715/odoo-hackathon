// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS ----------

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum VehicleType {
  VAN
  TRUCK
  MINI
  CAR
  BUS
  SUV
  PICKUP
  OTHER
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum ExpenseType {
  TOLL
  MAINTENANCE
  OTHER
}

// ---------- MODELS ----------

// Mirrors a row in Supabase auth.users (id is the same UUID).
// Do not manage passwords here — Supabase Auth handles that.
model Profile {
  id               String   @id @default(uuid()) @db.Uuid
  fullName  String
  email     String   @unique
  role      Role
  moduleAccess String[] @default([])
  passwordHash     String
  refreshTokenHash String?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdTrips Trip[] @relation("CreatedByProfile")

  @@map("profiles")
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique
  vehicleCode        String        @unique
  name               String
  manufacturer       String
  model              String
  type               VehicleType
  maxLoadCapacityKg  Float
  odometerKm         Float         @default(0)
  acquisitionCost    Float
  status             VehicleStatus @default(AVAILABLE)
  region             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@map("vehicles")
}

model Driver {
  id                String       @id @default(uuid())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Float        @default(100)
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  trips             Trip[]

  @@map("drivers")
}

model Trip {
  id              String     @id @default(uuid())
  source          String
  destination     String
  vehicleId       String
  driverId        String
  cargoWeightKg   Float
  plannedDistance Float
  actualDistance  Float?
  fuelConsumedL   Float?
  status          TripStatus @default(DRAFT)
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])
  driver          Driver     @relation(fields: [driverId], references: [id])
  createdByProfile Profile?  @relation("CreatedByProfile", fields: [createdByProfileId], references: [id])
  createdByProfileId String? @db.Uuid

  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceLog {
  id          String            @id @default(uuid())
  vehicleId   String
  description String
  cost        Float             @default(0)
  status      MaintenanceStatus @default(OPEN)
  openedAt    DateTime          @default(now())
  closedAt    DateTime?

  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("maintenance_logs")
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  liters    Float
  cost      Float
  date      DateTime @default(now())

  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("fuel_logs")
}

model Expense {
  id        String      @id @default(uuid())
  vehicleId String
  type      ExpenseType
  amount    Float
  note      String?
  date      DateTime    @default(now())

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("expenses")
}

model OrganizationSettings {
  id            Int      @id @default(1)
  orgName       String
  depotName     String
  currency      String   @default("LKR")
  distanceUnit  String   @default("KM")
  timezone      String   @default("Asia/Colombo")
  contactEmail  String?
  contactPhone  String?
  address       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("organization_settings")
}
